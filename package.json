{
  "name": "ccmixter-stem-downloader",
  "version": "0.2.0",
  "description": "Electron foundation for planning ccMixter stem library downloads.",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "pnpm package && playwright test",
    "test:e2e:headed": "pnpm package && playwright test --headed",
    "lint": "vitest run test/renderer-safety.test.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wavefile": "^11.0.0",
    "wavesurfer.js": "^7.12.10",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/plugin-webpack": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "22.20.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/yazl": "^3.3.1",
    "css-loader": "^7.1.4",
    "electron": "^33.4.11",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "playwright": "^1.61.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "webpack": "^5.108.3",
    "webpack-cli": "^5.1.4"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
